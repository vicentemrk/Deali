# Deali v2 Backend — Variables de entorno
# Copia este archivo a .env y rellena los valores

# ─── Supabase ────────────────────────────────────────────────────────────────
# URL del proyecto (sin trailing slash)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Service role key — NUNCA exponer en frontend, solo scrapers server-side
SUPABASE_SERVICE_ROLE_KEY=

# ─── Upstash Redis (invalidación de cache tras scrape) ───────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Scraper — Límites ───────────────────────────────────────────────────────
# Máximo de páginas VTEX por tienda (50 productos/página)
VTEX_MAX_PAGES=4
# Delay en ms entre requests VTEX
VTEX_DELAY_MS=300
# Concurrencia máxima de browsers (Playwright)
BROWSER_MAX_CONCURRENT=2

# ─── Cookies anti-bot (se actualizan periódicamente) ─────────────────────────
TOTTUS_COOKIE=
LIDER_COOKIE=
UNIMARC_COOKIE=
ACUENTA_COOKIE=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
