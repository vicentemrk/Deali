# Variables de Entorno - Deali

# URL del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública (segura en FE)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública del sitio (usar dominio de Vercel en producción)
NEXT_PUBLIC_APP_URL=

# Clave privada (solo server-side) - ¡NUNCA USAR NEXT_PUBLIC AQUÍ!
SUPABASE_SERVICE_ROLE_KEY=

# URL REST de Upstash Redis
UPSTASH_REDIS_REST_URL=

# Token de Upstash Redis - ¡NUNCA USAR NEXT_PUBLIC AQUÍ!
UPSTASH_REDIS_REST_TOKEN=

# Modo de ejecución de scraper admin:
# - queue: encola trabajos en la tabla scrape_jobs (recomendado en Vercel)
# - local: ejecuta npx tsx scripts/scrapeAll.ts desde la API (solo desarrollo local)
SCRAPER_EXECUTION_MODE=queue
